#!/bin/bash
set -euo pipefail

MARKER="${ISABEL_BOOTSTRAP_MARKER:-/var/lib/issabel/.bootstrapped}"
HTTP_PORT="${ISSABEL_HTTP_PORT:-80}"

[ -f "$MARKER" ]
pgrep -x mysqld >/dev/null
pgrep -x httpd >/dev/null
pgrep -x asterisk >/dev/null

curl -fsS --max-time 3 "http://127.0.0.1:${HTTP_PORT}/" >/dev/null
mysqladmin --socket=/var/lib/mysql/mysql.sock ping >/dev/null 2>&1
asterisk -rx "core show version" >/dev/null 2>&1
