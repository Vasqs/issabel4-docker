#!/bin/bash
set -euo pipefail

MARKER="${ISABEL_BOOTSTRAP_MARKER:-/var/lib/issabel/.bootstrapped}"
WEB_ADMIN_USER="${ISSABEL_WEB_ADMIN_USER:-admin}"
WEB_ADMIN_PASSWORD="${ISSABEL_WEB_ADMIN_PASSWORD:-DevAdmin123}"
PBX_DB_USER="${ISSABEL_PBX_DB_USER:-asteriskuser}"
PBX_DB_PASSWORD="${ISSABEL_PBX_DB_PASSWORD:-amp109}"
CALLCENTER_DB_USER="${ISSABEL_CALLCENTER_DB_USER:-asterisk}"
CALLCENTER_DB_PASSWORD="${ISSABEL_CALLCENTER_DB_PASSWORD:-asterisk}"
MYSQL_ROOT_PASSWORD="${ISSABEL_MYSQL_ROOT_PASSWORD:-iSsAbEl.2o17}"
ASTERISK_PACKAGE="${ISSABEL_INSTALL_ASTERISK_PACKAGE:-asterisk18}"
INSTALL_ISSABELBR_POST_PATCH="${ISSABEL_INSTALL_ISSABELBR_POST_PATCH:-1}"
HTTPS_REDIRECT_PORT="${ISSABEL_HTTPS_PORT:-8443}"
ISSABELBR_POST_PATCH_URL="https://raw.githubusercontent.com/ibinetwork/IssabelBR/refs/heads/master/patch-issabelbr.sh"
ISSABELBR_POST_PATCH_LOG="/var/log/issabelbr-post-install.log"
ISSABELBR_MYSQL_WRAPPER="/usr/local/bin/issabelbr-mysql-wrapper"
EL7_REPO_CONFIGURATOR="/usr/local/bin/configure-el7-repositories"
MYSQL_SOCKET="${ISSABEL_MYSQL_SOCKET:-/var/lib/mysql/mysql.sock}"
LEGACY_CREDENTIALS_FILE="${ISSABEL_LEGACY_CREDENTIALS_FILE:-/etc/issabel.conf}"

sql_escape() {
  printf "%s" "$1" | sed "s/'/''/g"
}

mysql_root() {
  MYSQL_PWD="$MYSQL_ROOT_PASSWORD" mysql --protocol=socket --socket="$MYSQL_SOCKET" -uroot "$@"
}

mysql_root_without_password() {
  mysql --protocol=socket --socket="$MYSQL_SOCKET" -uroot "$@"
}

ensure_mysql_root_password() {
  local escaped_password

  if mysql_root -N -B -e "SELECT 1" >/dev/null 2>&1; then
    return 0
  fi

  if ! mysql_root_without_password -N -B -e "SELECT 1" >/dev/null 2>&1; then
    echo "unable to authenticate as MySQL root with or without password" >&2
    return 1
  fi

  escaped_password="$(sql_escape "$MYSQL_ROOT_PASSWORD")"
  mysql_root_without_password <<SQL
SET PASSWORD FOR 'root'@'localhost' = PASSWORD('${escaped_password}');
FLUSH PRIVILEGES;
SQL

  mysql_root -N -B -e "SELECT 1" >/dev/null 2>&1
}

wait_for_mariadb() {
  local retries=60
  local delay=2

  until mysqladmin ping >/dev/null 2>&1; do
    retries=$((retries - 1))
    if [ "$retries" -le 0 ]; then
      echo "mariadb did not become ready in time" >&2
      return 1
    fi
    sleep "$delay"
  done
}

seed_databases() {
  mysql_root <<SQL
CREATE DATABASE IF NOT EXISTS asterisk;
CREATE DATABASE IF NOT EXISTS asteriskcdrdb;
CREATE DATABASE IF NOT EXISTS mya2billing;
CREATE DATABASE IF NOT EXISTS call_center;
GRANT ALL PRIVILEGES ON asterisk.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON asteriskcdrdb.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON mya2billing.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON call_center.* TO '${CALLCENTER_DB_USER}'@'localhost' IDENTIFIED BY '${CALLCENTER_DB_PASSWORD}';
FLUSH PRIVILEGES;
SQL
}

seed_pbx_schema() {
  local pbx_dump="/usr/share/issabelpbx/tmp/issabelpbx-database-dump.sql"
  local devices_table

  devices_table="$(mysql_root -N -B -e "USE asterisk; SHOW TABLES LIKE 'devices';" 2>/dev/null || true)"
  if [ "$devices_table" = "devices" ]; then
    return 0
  fi

  if [ ! -f "$pbx_dump" ]; then
    echo "pbx database dump not found at $pbx_dump" >&2
    return 1
  fi

  mysql_root asterisk <"$pbx_dump"
}

read_config_value() {
  local file_path="$1"
  local key="$2"

  [ -f "$file_path" ] || return 1
  grep -E "^${key}=" "$file_path" | tail -n 1 | cut -d"=" -f2-
}

read_php_conf_value() {
  local file_path="$1"
  local key="$2"

  [ -f "$file_path" ] || return 1
  grep -E "^\\\$amp_conf\\['${key}'\\]" "$file_path" | tail -n 1 | sed -E "s/^.*=[[:space:]]*'([^']*)';/\\1/"
}

read_manager_credentials() {
  local file_path="${1:-/etc/asterisk/manager.conf}"

  [ -f "$file_path" ] || return 1
  awk '
    /^[[:space:]]*[;#]/ { next }
    /^[[:space:]]*\[/ {
      if (match($0, /^[[:space:]]*\[([^]]+)\]/, parts)) {
        section = parts[1]
        order[++count] = section
      }
      next
    }
    /^[[:space:]]*[A-Za-z0-9_]+[[:space:]]*=/ {
      split($0, kv, "=")
      key = kv[1]
      value = substr($0, index($0, "=") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      data[section ":" key] = value
    }
    END {
      preferred = ""
      fallback = ""
      for (i = 1; i <= count; ++i) {
        current = order[i]
        if (current == "general") {
          continue
        }
        secret = data[current ":secret"]
        readperm = data[current ":read"]
        writeperm = data[current ":write"]
        if (secret != "" && readperm != "" && writeperm != "") {
          if (current == "admin") {
            preferred = current "\t" secret
            break
          }
          if (fallback == "") {
            fallback = current "\t" secret
          }
        }
      }
      if (preferred != "") {
        print preferred
      } else if (fallback != "") {
        print fallback
      }
    }
  ' "$file_path"
}

upsert_config_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  touch "$file_path"
  escaped_value="$(printf '%s' "$value" | sed 's/[\/&]/\\&/g')"
  if grep -qE "^${key}=" "$file_path"; then
    sed -i "s/^${key}=.*/${key}=${escaped_value}/" "$file_path"
  else
    printf '%s=%s\n' "$key" "$value" >>"$file_path"
  fi
}

ensure_config_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  [ -f "$file_path" ] || return 0

  escaped_value="$(printf '%s' "$value" | sed 's/[\/&]/\\&/g')"
  if grep -qE "^${key}=" "$file_path"; then
    sed -i "s/^${key}=.*/${key}=${escaped_value}/" "$file_path"
  else
    printf '%s=%s\n' "$key" "$value" >>"$file_path"
  fi
}

ensure_php_conf_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  [ -f "$file_path" ] || return 0

  escaped_value="$(printf '%s' "$value" | sed "s/[\/&]/\\\\&/g")"
  if grep -qE "^\\\$amp_conf\\['${key}'\\]" "$file_path"; then
    sed -i "s/^\\\$amp_conf\\['${key}'\\].*/\\\$amp_conf['${key}']\t= '${escaped_value}';/" "$file_path"
  else
    printf "\$amp_conf['%s']\t= '%s';\n" "$key" "$value" >>"$file_path"
  fi
}

reconcile_http_redirect_port() {
  local file_path="/etc/httpd/conf.d/issabel.conf"

  [ -f "$file_path" ] || return 0
  perl -0pi -e 's#RewriteRule \(.\*\) https://%\{HTTP_HOST\}%\{REQUEST_URI\}#RewriteCond %{HTTP_HOST} ^([^:]+)(?::\d+)?$\n    RewriteRule (.*) https://%1:'"$HTTPS_REDIRECT_PORT"'%{REQUEST_URI}#g' "$file_path"
}

reconcile_manager_secret() {
  local ami_user="$1"
  local ami_password="$2"
  local file_path="/etc/asterisk/manager.conf"
  local escaped_password

  [ -f "$file_path" ] || return 0

  escaped_password="$(printf '%s' "$ami_password" | sed 's/[\/&]/\\&/g')"
  perl -0pi -e 's#(\['"$ami_user"'\][^\[]*?^secret\s*=\s*).*$#${1}'"$escaped_password"'#ms' "$file_path"
  if ! grep -q "^\[$ami_user\]" "$file_path"; then
    cat >>"$file_path" <<EOF

[$ami_user]
secret = $ami_password
deny=0.0.0.0/0.0.0.0
permit=127.0.0.1/255.255.255.0
read = system,call,log,verbose,command,agent,user,config,command,dtmf,reporting,cdr,dialplan,originate
write = system,call,log,verbose,command,agent,user,config,command,dtmf,reporting,cdr,dialplan,originate
writetimeout = 5000
EOF
  fi
}

reconcile_database_configs() {
  ensure_config_value "/etc/amportal.conf" "AMPDBUSER" "$PBX_DB_USER"
  ensure_config_value "/etc/amportal.conf" "AMPDBPASS" "$PBX_DB_PASSWORD"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBUSER" "$PBX_DB_USER"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBPASS" "$PBX_DB_PASSWORD"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBNAME" "asterisk"
  ensure_config_value "/opt/issabel/dialer/dialerd.conf" "dbuser" "$CALLCENTER_DB_USER"
  ensure_config_value "/opt/issabel/dialer/dialerd.conf" "dbpass" "$CALLCENTER_DB_PASSWORD"
}

reconcile_callcenter_ami_config() {
  local ami_user="$1"
  local ami_password="$2"
  local valor_config_table

  valor_config_table="$(mysql_root -N -B -e "USE call_center; SHOW TABLES LIKE 'valor_config';" 2>/dev/null || true)"
  [ "$valor_config_table" = "valor_config" ] || return 0

  mysql_root <<SQL
DELETE FROM call_center.valor_config
WHERE config_key IN ('asterisk.asthost', 'asterisk.astuser', 'asterisk.astpass');
INSERT INTO call_center.valor_config (config_key, config_value)
VALUES
  ('asterisk.asthost', '127.0.0.1'),
  ('asterisk.astuser', '$(sql_escape "$ami_user")'),
  ('asterisk.astpass', '$(sql_escape "$ami_password")');
SQL
}

reconcile_ami_credentials() {
  local ami_admin_user
  local ami_admin_password
  local manager_credentials

  ami_admin_user="$(read_config_value "/etc/amportal.conf" "AMPMGRUSER" || true)"
  if [ -z "$ami_admin_user" ]; then
    ami_admin_user="$(read_php_conf_value "/etc/issabelpbx.conf" "AMPMGRUSER" || true)"
  fi
  if [ -z "$ami_admin_user" ]; then
    ami_admin_user="admin"
  fi

  manager_credentials="$(read_manager_credentials "/etc/asterisk/manager.conf" || true)"
  if [ -n "$manager_credentials" ]; then
    IFS=$'\t' read -r ami_admin_user ami_admin_password <<<"$manager_credentials"
  else
    ami_admin_password="$(read_config_value "/etc/amportal.conf" "AMPMGRPASS" || true)"
    if [ -z "$ami_admin_password" ]; then
      ami_admin_password="$(read_php_conf_value "/etc/issabelpbx.conf" "AMPMGRPASS" || true)"
    fi
  fi

  if [ -z "$ami_admin_password" ]; then
    ami_admin_password="amp111"
  fi

  reconcile_manager_secret "$ami_admin_user" "$ami_admin_password"
  upsert_config_value "$LEGACY_CREDENTIALS_FILE" "amiadminpwd" "$ami_admin_password"
  reconcile_callcenter_ami_config "$ami_admin_user" "$ami_admin_password"
}

reconcile_legacy_credentials() {
  upsert_config_value "$LEGACY_CREDENTIALS_FILE" "mysqlrootpwd" "$MYSQL_ROOT_PASSWORD"
  reconcile_ami_credentials
  chmod 600 "$LEGACY_CREDENTIALS_FILE" || true
}

reconcile_web_admin() {
  local acl_db="/var/www/db/acl.db"
  local web_admin_user_sql
  local web_admin_password_md5

  if [ ! -f "$acl_db" ]; then
    echo "acl database not found at $acl_db" >&2
    return 1
  fi

  web_admin_user_sql="$(sql_escape "$WEB_ADMIN_USER")"
  web_admin_password_md5="$(printf '%s' "$WEB_ADMIN_PASSWORD" | md5sum | awk '{print $1}')"

  sqlite3 "$acl_db" <<SQL
INSERT INTO acl_user (name, description, md5_password, extension)
SELECT '${web_admin_user_sql}', 'Docker provisioned administrator', '${web_admin_password_md5}', ''
WHERE NOT EXISTS (
  SELECT 1 FROM acl_user WHERE name = '${web_admin_user_sql}'
);
UPDATE acl_user
SET md5_password = '${web_admin_password_md5}'
WHERE name = '${web_admin_user_sql}';
INSERT INTO acl_membership (id_user, id_group)
SELECT u.id, g.id
FROM acl_user u
JOIN acl_group g ON g.name = 'administrator'
WHERE u.name = '${web_admin_user_sql}'
AND NOT EXISTS (
  SELECT 1
  FROM acl_membership m
  WHERE m.id_user = u.id AND m.id_group = g.id
);
SQL
}

apply_issabel_repairs() {
  if command -v amportal >/dev/null 2>&1; then
    amportal chown || true
  fi
}

configure_el7_repositories() {
  "$EL7_REPO_CONFIGURATOR"
}

issabelbr_post_patch_is_supported() {
  case "$ASTERISK_PACKAGE" in
    asterisk11|asterisk13)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

apply_issabelbr_post_patch() {
  case "${INSTALL_ISSABELBR_POST_PATCH,,}" in
    1|true|yes|y|on) ;;
    *)
      return 0
      ;;
  esac

  if ! issabelbr_post_patch_is_supported; then
    echo "skipping IssabelBR post-install patch for unsupported package ${ASTERISK_PACKAGE}" >&2
    return 0
  fi

  (
    local script_path
    local cleanup
    local patch_wrapper_dir

    script_path="$(mktemp /tmp/issabelbr-post-patch.XXXXXX.sh)"
    patch_wrapper_dir="$(mktemp -d /tmp/issabelbr-post-patch-bin.XXXXXX)"
    cleanup() {
      rm -f "$script_path"
      rm -rf "$patch_wrapper_dir"
    }
    trap cleanup EXIT
    ln -s "$ISSABELBR_MYSQL_WRAPPER" "$patch_wrapper_dir/mysql"
    wget -O "$script_path" "$ISSABELBR_POST_PATCH_URL"
    chmod +x "$script_path"
    PATH="$patch_wrapper_dir:$PATH" ISSABELBR_REAL_MYSQL="/usr/bin/mysql" \
      ISSABELBR_MYSQL_ROOT_PASSWORD="$MYSQL_ROOT_PASSWORD" \
      bash "$script_path" 2>&1 | tee "$ISSABELBR_POST_PATCH_LOG"
  )
}

main() {
  reconcile_web_admin
  wait_for_mariadb
  ensure_mysql_root_password
  seed_databases
  seed_pbx_schema
  reconcile_database_configs
  reconcile_legacy_credentials
  reconcile_http_redirect_port

  if [ -f "$MARKER" ]; then
    exit 0
  fi

  apply_issabel_repairs
  configure_el7_repositories
  apply_issabelbr_post_patch
  touch "$MARKER"
}

main "$@"
