#!/bin/bash
set -euo pipefail

MARKER="${ISABEL_BOOTSTRAP_MARKER:-/var/lib/issabel/.bootstrapped}"
WEB_ADMIN_USER="${ISSABEL_WEB_ADMIN_USER:-admin}"
WEB_ADMIN_PASSWORD="${ISSABEL_WEB_ADMIN_PASSWORD:-DevAdmin123}"
PBX_DB_USER="${ISSABEL_PBX_DB_USER:-asteriskuser}"
PBX_DB_PASSWORD="${ISSABEL_PBX_DB_PASSWORD:-amp109}"
CALLCENTER_DB_USER="${ISSABEL_CALLCENTER_DB_USER:-asterisk}"
CALLCENTER_DB_PASSWORD="${ISSABEL_CALLCENTER_DB_PASSWORD:-asterisk}"
MYSQL_ROOT_PASSWORD="${ISSABEL_MYSQL_ROOT_PASSWORD:-iSsAbEl.2o17}"
ASTERISK_PACKAGE="${ISSABEL_INSTALL_ASTERISK_PACKAGE:-asterisk18}"
HTTPS_REDIRECT_PORT="${ISSABEL_HTTPS_PORT:-8443}"
SIP_PORT="${ISSABEL_SIP_PORT:-5060}"
SIP_BIND_ADDRESS="${ISSABEL_SIP_BIND_ADDRESS:-0.0.0.0}"
SIP_EXTERNAL_ADDRESS="${ISSABEL_SIP_EXTERNAL_ADDRESS:-}"
SIP_LOCALNETS="${ISSABEL_SIP_LOCALNETS:-}"
RTP_START="${ISSABEL_RTP_START:-10000}"
RTP_END="${ISSABEL_RTP_END:-10100}"
MYSQL_SOCKET="${ISSABEL_MYSQL_SOCKET:-/var/lib/mysql/mysql.sock}"
LEGACY_CREDENTIALS_FILE="${ISSABEL_LEGACY_CREDENTIALS_FILE:-/etc/issabel.conf}"

sql_escape() {
  printf "%s" "$1" | sed "s/'/''/g"
}

mysql_root() {
  MYSQL_PWD="$MYSQL_ROOT_PASSWORD" mysql --protocol=socket --socket="$MYSQL_SOCKET" -uroot "$@"
}

mysql_root_without_password() {
  mysql --protocol=socket --socket="$MYSQL_SOCKET" -uroot "$@"
}

ensure_mysql_root_password() {
  local escaped_password

  if mysql_root -N -B -e "SELECT 1" >/dev/null 2>&1; then
    return 0
  fi

  if ! mysql_root_without_password -N -B -e "SELECT 1" >/dev/null 2>&1; then
    echo "unable to authenticate as MySQL root with or without password" >&2
    return 1
  fi

  escaped_password="$(sql_escape "$MYSQL_ROOT_PASSWORD")"
  mysql_root_without_password <<SQL
SET PASSWORD FOR 'root'@'localhost' = PASSWORD('${escaped_password}');
FLUSH PRIVILEGES;
SQL

  mysql_root -N -B -e "SELECT 1" >/dev/null 2>&1
}

wait_for_mariadb() {
  local retries=60
  local delay=2

  until mysqladmin ping >/dev/null 2>&1; do
    retries=$((retries - 1))
    if [ "$retries" -le 0 ]; then
      echo "mariadb did not become ready in time" >&2
      return 1
    fi
    sleep "$delay"
  done
}

seed_databases() {
  mysql_root <<SQL
CREATE DATABASE IF NOT EXISTS asterisk;
CREATE DATABASE IF NOT EXISTS asteriskcdrdb;
CREATE DATABASE IF NOT EXISTS mya2billing;
CREATE DATABASE IF NOT EXISTS call_center;
GRANT ALL PRIVILEGES ON asterisk.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON asteriskcdrdb.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON mya2billing.* TO '${PBX_DB_USER}'@'localhost' IDENTIFIED BY '${PBX_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON call_center.* TO '${CALLCENTER_DB_USER}'@'localhost' IDENTIFIED BY '${CALLCENTER_DB_PASSWORD}';
FLUSH PRIVILEGES;
SQL
}

seed_pbx_schema() {
  local pbx_dump="/usr/share/issabelpbx/tmp/issabelpbx-database-dump.sql"
  local devices_table

  devices_table="$(mysql_root -N -B -e "USE asterisk; SHOW TABLES LIKE 'devices';" 2>/dev/null || true)"
  if [ "$devices_table" = "devices" ]; then
    return 0
  fi

  if [ ! -f "$pbx_dump" ]; then
    echo "pbx database dump not found at $pbx_dump" >&2
    return 1
  fi

  mysql_root asterisk <"$pbx_dump"
}

find_callcenter_schema() {
  local schema_path

  for schema_path in \
    /usr/share/issabel/module_installer/issabel-callcenter-*/setup/firstboot_call_center.sql \
    /usr/share/issabel/module_installer/issabel-callcenter-*/setup/call_center.sql
  do
    if [ -f "$schema_path" ]; then
      printf '%s\n' "$schema_path"
      return 0
    fi
  done

  return 1
}

seed_callcenter_schema() {
  local agent_table
  local callcenter_schema

  agent_table="$(mysql_root -N -B -e "USE call_center; SHOW TABLES LIKE 'agent';" 2>/dev/null || true)"
  if [ "$agent_table" = "agent" ]; then
    return 0
  fi

  if ! callcenter_schema="$(find_callcenter_schema)"; then
    echo "call center schema dump not found under /usr/share/issabel/module_installer" >&2
    return 1
  fi

  mysql_root <"$callcenter_schema"
}

read_config_value() {
  local file_path="$1"
  local key="$2"

  [ -f "$file_path" ] || return 1
  grep -E "^${key}=" "$file_path" | tail -n 1 | cut -d"=" -f2-
}

read_php_conf_value() {
  local file_path="$1"
  local key="$2"

  [ -f "$file_path" ] || return 1
  grep -E "^\\\$amp_conf\\['${key}'\\]" "$file_path" | tail -n 1 | sed -E "s/^.*=[[:space:]]*'([^']*)';/\\1/"
}

read_manager_credentials() {
  local file_path="${1:-/etc/asterisk/manager.conf}"

  [ -f "$file_path" ] || return 1
  awk '
    /^[[:space:]]*[;#]/ { next }
    /^[[:space:]]*\[/ {
      if (match($0, /^[[:space:]]*\[([^]]+)\]/, parts)) {
        section = parts[1]
        order[++count] = section
      }
      next
    }
    /^[[:space:]]*[A-Za-z0-9_]+[[:space:]]*=/ {
      split($0, kv, "=")
      key = kv[1]
      value = substr($0, index($0, "=") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      data[section ":" key] = value
    }
    END {
      preferred = ""
      fallback = ""
      for (i = 1; i <= count; ++i) {
        current = order[i]
        if (current == "general") {
          continue
        }
        secret = data[current ":secret"]
        readperm = data[current ":read"]
        writeperm = data[current ":write"]
        if (secret != "" && readperm != "" && writeperm != "") {
          if (current == "admin") {
            preferred = current "\t" secret
            break
          }
          if (fallback == "") {
            fallback = current "\t" secret
          }
        }
      }
      if (preferred != "") {
        print preferred
      } else if (fallback != "") {
        print fallback
      }
    }
  ' "$file_path"
}

upsert_config_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  touch "$file_path"
  escaped_value="$(printf '%s' "$value" | sed 's/[\/&]/\\&/g')"
  if grep -qE "^${key}=" "$file_path"; then
    sed -i "s/^${key}=.*/${key}=${escaped_value}/" "$file_path"
  else
    printf '%s=%s\n' "$key" "$value" >>"$file_path"
  fi
}

ensure_config_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  [ -f "$file_path" ] || return 0

  escaped_value="$(printf '%s' "$value" | sed 's/[\/&]/\\&/g')"
  if grep -qE "^${key}=" "$file_path"; then
    sed -i "s/^${key}=.*/${key}=${escaped_value}/" "$file_path"
  else
    printf '%s=%s\n' "$key" "$value" >>"$file_path"
  fi
}

ensure_php_conf_value() {
  local file_path="$1"
  local key="$2"
  local value="$3"
  local escaped_value

  [ -f "$file_path" ] || return 0

  escaped_value="$(printf '%s' "$value" | sed "s/[\/&]/\\\\&/g")"
  if grep -qE "^\\\$amp_conf\\['${key}'\\]" "$file_path"; then
    sed -i "s/^\\\$amp_conf\\['${key}'\\].*/\\\$amp_conf['${key}']\t= '${escaped_value}';/" "$file_path"
  else
    printf "\$amp_conf['%s']\t= '%s';\n" "$key" "$value" >>"$file_path"
  fi
}

normalize_network_lines() {
  tr ', ' '\n\n' | sed '/^$/d'
}

detect_sip_localnets() {
  local discovered

  discovered="$(ip -4 -o route show scope link 2>/dev/null | awk '{print $1}' | sed '/^default$/d' || true)"
  if [ -n "$discovered" ]; then
    printf '%s\n' "$discovered" | normalize_network_lines
    return 0
  fi

  ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | normalize_network_lines || true
}

render_sip_external_setting() {
  local address="$1"

  [ -n "$address" ] || return 0
  if [[ "$address" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf 'externip=%s\n' "$address"
  else
    printf 'externhost=%s\nexternrefresh=60\n' "$address"
  fi
}

reconcile_sip_bridge_settings() {
  local sip_file="/etc/asterisk/sip_general_custom.conf"
  local rtp_file="/etc/asterisk/rtp_custom.conf"
  local localnets

  localnets="$SIP_LOCALNETS"
  if [ -z "$localnets" ]; then
    localnets="$(detect_sip_localnets)"
  fi

  {
    printf '; Managed by issabel-firstboot for Docker bridge SIP access\n'
    printf 'udpbindaddr=%s:%s\n' "$SIP_BIND_ADDRESS" "$SIP_PORT"
    printf 'nat=force_rport,comedia\n'
    render_sip_external_setting "$SIP_EXTERNAL_ADDRESS"
    while IFS= read -r network; do
      [ -n "$network" ] || continue
      printf 'localnet=%s\n' "$network"
    done <<<"$localnets"
  } >"$sip_file"

  {
    printf '; Managed by issabel-firstboot for Docker bridge RTP access\n'
    printf 'rtpstart=%s\n' "$RTP_START"
    printf 'rtpend=%s\n' "$RTP_END"
  } >"$rtp_file"

  chown asterisk:asterisk "$sip_file" "$rtp_file" 2>/dev/null || true
}

reconcile_http_redirect_port() {
  local file_path="/etc/httpd/conf.d/issabel.conf"

  [ -f "$file_path" ] || return 0
  python - "$file_path" "$HTTPS_REDIRECT_PORT" <<'PY'
import io
import sys

path = sys.argv[1]
https_port = sys.argv[2]
with io.open(path, 'r', encoding='utf-8') as fh:
    text = fh.read()
original = """    RewriteCond %{HTTPS} off
    RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI}
"""
replacement = """    RewriteCond %%{HTTPS} off
    RewriteCond %%{HTTP_HOST} ^([^:]+)(?::\\d+)?$
    RewriteRule (.*) https://%%1:%s%%{REQUEST_URI}
""" % https_port
if original in text:
    text = text.replace(original, replacement, 1)
with io.open(path, 'w', encoding='utf-8') as fh:
    fh.write(text)
PY
}

reconcile_manager_secret() {
  local ami_user="$1"
  local ami_password="$2"
  local file_path="/etc/asterisk/manager.conf"
  local read_permissions="system,call,log,verbose,command,agent,user,config,command,dtmf,reporting,cdr,dialplan,originate"
  local write_permissions="system,call,log,verbose,command,agent,user,config,command,dtmf,reporting,cdr,dialplan,originate"

  [ -f "$file_path" ] || return 0

  python - "$file_path" "$ami_user" "$ami_password" "$read_permissions" "$write_permissions" <<'PY'
import io
import sys

path = sys.argv[1]
ami_user = sys.argv[2]
ami_password = sys.argv[3]
read_permissions = sys.argv[4]
write_permissions = sys.argv[5]

with io.open(path, 'r', encoding='utf-8') as fh:
    lines = fh.read().splitlines()
sections = []
current_header = None
current_lines = []

for line in lines:
    stripped = line.strip()
    if stripped.startswith('[') and stripped.endswith(']'):
        if current_header is not None:
            sections.append((current_header, current_lines))
        current_header = stripped[1:-1]
        current_lines = [line]
    else:
        if current_header is None:
            current_header = ''
        current_lines.append(line)
if current_header is not None:
    sections.append((current_header, current_lines))

if not any(header == 'general' for header, _ in sections):
    sections.insert(0, ('general', ['[general]']))

new_sections = []
ami_found = False
for header, section_lines in sections:
    if header == 'general':
        updated = []
        channelvars_found = False
        port_index = None
        for idx, line in enumerate(section_lines):
            stripped = line.strip()
            if stripped.startswith('channelvars'):
                updated.append('channelvars = DIALERID,DIALERVAR')
                channelvars_found = True
            else:
                updated.append(line)
            if stripped.startswith('port'):
                port_index = len(updated) - 1
        if not channelvars_found:
            insert_at = port_index + 1 if port_index is not None else len(updated)
            updated.insert(insert_at, 'channelvars = DIALERID,DIALERVAR')
        new_sections.append((header, updated))
        continue

    if header != ami_user:
        new_sections.append((header, section_lines))
        continue

    ami_found = True
    updated = ['[{0}]'.format(ami_user)]
    preserved = []
    for line in section_lines[1:]:
        stripped = line.strip()
        if stripped == '':
            continue
        if stripped.startswith(('secret', 'deny', 'permit', 'read', 'write', 'writetimeout')):
            continue
        preserved.append(line)
    updated.extend([
        'secret = {0}'.format(ami_password),
        'deny=0.0.0.0/0.0.0.0',
        'permit=127.0.0.1/255.255.255.0',
        'read = {0}'.format(read_permissions),
        'write = {0}'.format(write_permissions),
        'writetimeout = 5000',
    ])
    updated.extend(preserved)
    new_sections.append((header, updated))

if not ami_found:
    new_sections.append((ami_user, [
        '[{0}]'.format(ami_user),
        'secret = {0}'.format(ami_password),
        'deny=0.0.0.0/0.0.0.0',
        'permit=127.0.0.1/255.255.255.0',
        'read = {0}'.format(read_permissions),
        'write = {0}'.format(write_permissions),
        'writetimeout = 5000',
    ]))

output = []
for idx, (_, section_lines) in enumerate(new_sections):
    if idx > 0 and output and output[-1] != '':
        output.append('')
    output.extend(section_lines)

with io.open(path, 'w', encoding='utf-8') as fh:
    fh.write(u'\n'.join(output) + u'\n')
PY
}

reconcile_manager_general_settings() {
  local file_path="/etc/asterisk/manager.conf"

  [ -f "$file_path" ] || return 0

  python - "$file_path" <<'PY'
import io
import sys

path = sys.argv[1]
with io.open(path, 'r', encoding='utf-8') as fh:
    lines = fh.read().splitlines()

sections = []
current_header = None
current_lines = []
for line in lines:
    stripped = line.strip()
    if stripped.startswith('[') and stripped.endswith(']'):
        if current_header is not None:
            sections.append((current_header, current_lines))
        current_header = stripped[1:-1]
        current_lines = [line]
    else:
        if current_header is None:
            current_header = ''
        current_lines.append(line)
if current_header is not None:
    sections.append((current_header, current_lines))

if not any(header == 'general' for header, _ in sections):
    sections.insert(0, ('general', ['[general]']))

new_sections = []
for header, section_lines in sections:
    if header != 'general':
        new_sections.append((header, section_lines))
        continue

    updated = []
    enabled_found = False
    bindaddr_found = False
    port_found = False
    channelvars_found = False
    for line in section_lines:
        stripped = line.strip()
        if stripped.startswith('enabled'):
            updated.append('enabled = yes')
            enabled_found = True
        elif stripped.startswith('bindaddr'):
            updated.append('bindaddr = 0.0.0.0')
            bindaddr_found = True
        elif stripped.startswith('port'):
            updated.append('port = 5038')
            port_found = True
        elif stripped.startswith('channelvars'):
            updated.append('channelvars = DIALERID,DIALERVAR')
            channelvars_found = True
        else:
            updated.append(line)
    if not enabled_found:
        updated.append('enabled = yes')
    if not bindaddr_found:
        updated.append('bindaddr = 0.0.0.0')
    if not port_found:
        updated.append('port = 5038')
    if not channelvars_found:
        updated.append('channelvars = DIALERID,DIALERVAR')
    new_sections.append((header, updated))

output = []
for idx, (_, section_lines) in enumerate(new_sections):
    if idx > 0 and output and output[-1] != '':
        output.append('')
    output.extend(section_lines)

with io.open(path, 'w', encoding='utf-8') as fh:
    fh.write(u'\n'.join(output) + u'\n')
PY
}

normalize_agents_conf() {
  local file_path="/etc/asterisk/agents.conf"

  [ -f "$file_path" ] || return 0
  if ! grep -q '^\[agents\]$' "$file_path"; then
    printf '\n[agents]\n' >>"$file_path"
  fi
}

reconcile_database_configs() {
  ensure_config_value "/etc/amportal.conf" "AMPDBUSER" "$PBX_DB_USER"
  ensure_config_value "/etc/amportal.conf" "AMPDBPASS" "$PBX_DB_PASSWORD"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBUSER" "$PBX_DB_USER"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBPASS" "$PBX_DB_PASSWORD"
  ensure_php_conf_value "/etc/issabelpbx.conf" "AMPDBNAME" "asterisk"
  ensure_config_value "/opt/issabel/dialer/dialerd.conf" "dbuser" "$CALLCENTER_DB_USER"
  ensure_config_value "/opt/issabel/dialer/dialerd.conf" "dbpass" "$CALLCENTER_DB_PASSWORD"
}

reconcile_callcenter_ami_config() {
  local ami_user="$1"
  local ami_password="$2"
  local valor_config_table

  valor_config_table="$(mysql_root -N -B -e "USE call_center; SHOW TABLES LIKE 'valor_config';" 2>/dev/null || true)"
  [ "$valor_config_table" = "valor_config" ] || return 0

  mysql_root <<SQL
DELETE FROM call_center.valor_config
WHERE config_key IN ('asterisk.asthost', 'asterisk.astuser', 'asterisk.astpass');
INSERT INTO call_center.valor_config (config_key, config_value)
VALUES
  ('asterisk.asthost', '127.0.0.1'),
  ('asterisk.astuser', '$(sql_escape "$ami_user")'),
  ('asterisk.astpass', '$(sql_escape "$ami_password")');
SQL
}

reconcile_ami_credentials() {
  local ami_admin_user
  local ami_admin_password

  ami_admin_user="$(read_config_value "/etc/amportal.conf" "AMPMGRUSER" || true)"
  if [ -z "$ami_admin_user" ]; then
    ami_admin_user="$(read_php_conf_value "/etc/issabelpbx.conf" "AMPMGRUSER" || true)"
  fi
  if [ -z "$ami_admin_user" ]; then
    ami_admin_user="admin"
  fi

  ami_admin_password="$(read_config_value "/etc/amportal.conf" "AMPMGRPASS" || true)"
  if [ -z "$ami_admin_password" ]; then
    ami_admin_password="$(read_php_conf_value "/etc/issabelpbx.conf" "AMPMGRPASS" || true)"
  fi

  if [ -z "$ami_admin_password" ]; then
    ami_admin_password="amp111"
  fi

  reconcile_manager_secret "$ami_admin_user" "$ami_admin_password"
  reconcile_manager_general_settings
  upsert_config_value "$LEGACY_CREDENTIALS_FILE" "amiadminpwd" "$ami_admin_password"
  reconcile_callcenter_ami_config "$ami_admin_user" "$ami_admin_password"
}

reconcile_legacy_credentials() {
  upsert_config_value "$LEGACY_CREDENTIALS_FILE" "mysqlrootpwd" "$MYSQL_ROOT_PASSWORD"
  reconcile_ami_credentials
  normalize_agents_conf
  chmod 600 "$LEGACY_CREDENTIALS_FILE" || true
}

reconcile_web_admin() {
  local acl_db="/var/www/db/acl.db"
  local web_admin_user_sql
  local web_admin_password_md5

  if [ ! -f "$acl_db" ]; then
    echo "acl database not found at $acl_db" >&2
    return 1
  fi

  web_admin_user_sql="$(sql_escape "$WEB_ADMIN_USER")"
  web_admin_password_md5="$(printf '%s' "$WEB_ADMIN_PASSWORD" | md5sum | awk '{print $1}')"

  sqlite3 "$acl_db" <<SQL
INSERT INTO acl_user (name, description, md5_password, extension)
SELECT '${web_admin_user_sql}', 'Docker provisioned administrator', '${web_admin_password_md5}', ''
WHERE NOT EXISTS (
  SELECT 1 FROM acl_user WHERE name = '${web_admin_user_sql}'
);
UPDATE acl_user
SET md5_password = '${web_admin_password_md5}'
WHERE name = '${web_admin_user_sql}';
INSERT INTO acl_membership (id_user, id_group)
SELECT u.id, g.id
FROM acl_user u
JOIN acl_group g ON g.name = 'administrator'
WHERE u.name = '${web_admin_user_sql}'
AND NOT EXISTS (
  SELECT 1
  FROM acl_membership m
  WHERE m.id_user = u.id AND m.id_group = g.id
);
SQL
}

apply_issabel_repairs() {
  if command -v amportal >/dev/null 2>&1; then
    amportal chown || true
  fi
}

main() {
  reconcile_web_admin
  wait_for_mariadb
  ensure_mysql_root_password
  seed_databases
  seed_pbx_schema
  seed_callcenter_schema
  reconcile_database_configs
  reconcile_legacy_credentials
  reconcile_sip_bridge_settings
  reconcile_http_redirect_port

  if [ -f "$MARKER" ]; then
    exit 0
  fi

  apply_issabel_repairs
  touch "$MARKER"
}

main "$@"
